{
  "name": "chemsketcher",
  "productName": "ChemSketcher",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Ketcher-based desktop chemical structure editor with a live physicochemical property table (RDKit backend)",
  "author": "Morreale Lab <morreale.lab@gmail.com>",
  "license": "MIT",
  "//appConfig": "Single source of truth for app identity + ports (OneProduction convention). Everything else derives from this — do not hard-code these values elsewhere.",
  "appConfig": {
    "appIdNamespace": "tech.morrealelab",
    "devPort": 5573,
    "apiPort": 8573
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "desktop": "node desktop/scripts/dev.mjs",
    "desktop:install": "npm --prefix desktop install"
  },
  "dependencies": {
    "@tanstack/react-table": "^8.20.5",
    "ketcher-core": "^3.15.0",
    "ketcher-react": "^3.15.0",
    "ketcher-standalone": "^3.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.8"
  }
}
